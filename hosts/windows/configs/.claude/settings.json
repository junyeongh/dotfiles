{
  // Common
  "effortLevel": "high",
  "model": "opusplan",
  "voiceEnabled": true,
  "enabledPlugins": {
    "figma@claude-plugins-official": false,
    "github@claude-plugins-official": false
  },
  // Windows
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File %USERPROFILE%\\.claude\\hooks\\claude-hook-toast.ps1"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File %USERPROFILE%\\.claude\\hooks\\claude-hook-toast.ps1"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File %USERPROFILE%\\.claude\\hooks\\claude-hook-toast.ps1"
          }
        ]
      }
    ]
  }
}
