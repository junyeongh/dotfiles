{
  "debugger": {
    "dock": "left"
  },
  "agent": {
    "default_model": {
      "model": "claude-sonnet-4.6",
      "provider": "copilot_chat"
    },
    "default_profile": "minimal",
    "inline_assistant_model": {
      "model": "claude-sonnet-4.6",
      "provider": "copilot_chat"
    },
    "play_sound_when_agent_done": true,
    "use_modifier_to_send": true
  },
  "autosave": "on_focus_change",
  "buffer_font_family": "D2CodingLigature Nerd Font",
  "buffer_font_size": 16,
  "collaboration_panel": {
    "button": false
  },
  "document_folding_ranges": "on",
  "edit_predictions": {
    "disabled_globs": [],
    "mode": "subtle",
    "provider": "copilot"
  },
  "ensure_final_newline_on_save": false,
  "format_on_save": "off",
  "git": {
    "inline_blame": {
      "show_commit_summary": true
    }
  },
  "git_panel": {
    "sort_by_path": true,
    "tree_view": true,
    "dock": "right"
  },
  "helix_mode": false,
  "icon_theme": "Material Icon Theme",
  "notification_panel": {
    "button": false
  },
  "outline_panel": {
    "dock": "right"
  },
  "project_panel": {
    "hide_gitignore": false
  },
  "semantic_tokens": "combined",
  "session": {
    "trust_all_worktrees": true
  },
  "show_edit_predictions": true,
  "show_whitespaces": "all",
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": true
  },
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "terminal": {
    "font_family": "FiraCode Nerd Font",
    "font_size": 12,
    "line_height": "standard",
    "toolbar": {
      "breadcrumbs": true
    }
  },
  "theme": "Nord Dark",
  "title_bar": {
    "show_branch_icon": true,
    "show_menus": true
  },
  "ui_font_size": 16,
  "use_system_window_tabs": false,
  "vim_mode": true,
  "which_key": {
    "enabled": true
  }
}
