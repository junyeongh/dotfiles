{
  //////////////////////////////////////////////////
  // Languages specific
  "[c]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.tabSize": 4
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[ignore]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[just]": {
    "editor.defaultFormatter": "nefrob.vscode-just-syntax"
  },
  "[markdown]": {
    "editor.autoClosingBrackets": "beforeWhitespace",
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.wordWrap": "on",
    "files.trimTrailingWhitespace": false // 'double-space + enter' creates line break
  },
  "[nix]": {
    "editor.defaultFormatter": "jnoortheen.nix-ide"
  },
  "[powershell]": {
    "editor.defaultFormatter": "ms-vscode.powershell"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.tabSize": 4
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.tabSize": 4
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "[typst]": {
    "editor.defaultFormatter": "myriad-dreamin.tinymist"
  },
  "[vhdl]": {
    "editor.fontLigatures": false
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "blockman.n33A01B2FromDepth0ToInwardForAllBackgrounds": "45,0,0,2; none",
  // "breadcrumbs.filePath": "last",
  "chat.agent.enabled": true,
  // "chat.disableAIFeatures": true,
  "chat.math.enabled": true,
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true,
    "cursor-global": true,
    "cursor-workspace": true,
    "windsurf": true
  },
  "chat.mcp.gallery.enabled": true,
  "chat.tools.confirmationCarousel.enabled": true,
  "chat.useAgentSkills": true,
  "chat.viewSessions.orientation": "stacked",
  "chatgpt.commentCodeLensEnabled": false,
  "chatgpt.composerEnterBehavior": "cmdIfMultiline",
  "claudeCode.preferredLocation": "panel",
  "claudeCode.useCtrlEnterToSend": true,
  "color-highlight.enable": false,
  "debug.toolBarLocation": "docked",
  "diffEditor.experimental.showMoves": true,
  "diffEditor.experimental.useTrueInlineView": true,
  "diffEditor.ignoreTrimWhitespace": true,
  // editor
  "editor.aiStats.enabled": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports.biome": "explicit"
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.folding": false,
  "editor.fontFamily": "'D2CodingLigature Nerd Font','FiraCode Nerd Font', Consolas, monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 16,
  "editor.guides.bracketPairs": "active",
  "editor.indentSize": "tabSize",
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.inlineSuggest.minShowDelay": 100,
  "editor.linkedEditing": true,
  "editor.minimap.autohide": "mouseover",
  "editor.minimap.renderCharacters": false,
  "editor.minimap.sectionHeaderFontSize": 18,
  "editor.pasteAs.preferences": ["text.plain"],
  "editor.renderLineHighlight": "all",
  "editor.renderWhitespace": "all",
  "editor.rulers": [80, 100, 120],
  "editor.smoothScrolling": true,
  "editor.tabSize": 2,
  "errorLens.excludeBySource": ["cSpell", "Harper"],
  "errorLens.gutterIconsEnabled": true,
  "evenBetterToml.formatter.arrayTrailingComma": true,
  "evenBetterToml.schema.links": true,
  // explorer
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.fileNesting.patterns": {
    "*.dart": "${capture}.g.dart",
    "*.db": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.s3db": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.sqlite": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.ts": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "Cargo.toml": "Cargo.lock",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "pubspec.yaml": "pubspec.lock,pubspec_overrides.yaml,.packages,.flutter-plugins,.flutter-plugins-dependencies,.metadata",
    "tsconfig.json": "tsconfig.*.json"
  },
  "explorer.sortOrder": "type",
  "extensions.allowOpenInModalEditor": true,
  "files.associations": {
    "*.css": "tailwindcss",
    "*.mdx": "markdown",
    "*config*": "properties",
    ".aliases": "shellscript",
    ".json": "jsonc",
    ".prettierrc": "jsonc"
  },
  "files.autoSave": "onFocusChange",
  "files.trimTrailingWhitespace": true,
  "foam.completion.linkFormat": "link",
  "foam.files.newNotePath": "currentDir",
  "frontMatter.content.wysiwyg": false,
  // git
  "git-graph.date.format": "ISO Date & Time",
  "git.autofetch": true,
  "git.blame.editorDecoration.enabled": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "always",
  "git.verboseCommit": true,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.enable": {
    "*": false
  },
  "github.copilot.nextEditSuggestions.eagerness": "low",
  "github.copilot.nextEditSuggestions.enabled": true,
  "githubPullRequests.createOnPublishBranch": "never",
  "githubPullRequests.pullBranch": "never",
  "go.inlayHints.parameterNames": true,
  "go.toolsManagement.autoUpdate": false,
  "indentRainbow.colors": [
    "rgba(255, 0, 0, 0.5)",
    "rgba(255, 127, 0, 0.5)",
    "rgba(255, 255, 0, 0.5)",
    "rgba(0, 255, 0, 0.5)",
    "rgba(0, 0, 255, 0.5)",
    "rgba(75, 0, 130, 0.5)",
    "rgba(148, 0, 211, 0.5)"
  ],
  "indentRainbow.indicatorStyle": "light",
  "indentRainbow.lightIndicatorStyleLineWidth": 2,
  "inlineChat.enableV2": true,
  "inlineChat.notebookAgent": true,
  "js/ts.format.insertSpaceAfterOpeningAndBeforeClosingTemplateStringBraces": true,
  "js/ts.inlayHints.enumMemberValues.enabled": true,
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.inlayHints.parameterNames.enabled": "all",
  "js/ts.inlayHints.parameterTypes.enabled": true,
  "js/ts.inlayHints.propertyDeclarationTypes.enabled": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "json.format.keepLines": true, // on and off when needed
  "json.schemaDownload.trustedDomains": {
    "*": true
    // "https://developer.microsoft.com/json-schemas/": true,
    // "https://json-schema.org/": true,
    // "https://json.schemastore.org/": true,
    // "https://raw.githubusercontent.com": true,
    // "https://schemastore.azurewebsites.net/": true,
    // "https://ui.shadcn.com/schema.json": true,
    // "https://www.schemastore.org/": true
  },
  "markdown-pdf.highlightStyle": "github.css",
  "markdown-preview-github-styles.colorTheme": "system",
  "markdown.extension.list.indentationSize": "inherit",
  "markdown.extension.tableFormatter.normalizeIndentation": true,
  "markdown.preview.breaks": true,
  "markdownlint.config": {
    "MD004": false, // Unordered list style
    "MD010": false, // Hard tabs
    "MD018": false, // No space after hash on atx style heading
    "MD024": false, // Multiple headings with the same content
    "MD026": false, // Trailing punctuation in heading
    "MD028": false, // Blank line inside blockquote
    "MD029": false, // Ordered list item prefix
    "MD031": false, // Fenced code blocks should be surrounded by blank lines
    "MD033": false, // Inline HTML
    // "MD034": false, // Bare URL used
    "MD036": false, // Emphasis used instead of a heading
    "MD040": false, // Fenced code blocks should have a language specified
    "MD041": false, // First line in a file should be a top-level heading
    "MD045": false, // Images should have alternate text (alt text)
    // "MD051": false, // Link fragments should be valid
    "MD053": false, // Link and image reference definitions should be needed
    "MD058": false, // Tables should be surrounded by blank lines
    "MD060": false,
    // "MD060": {
    //   "style": "compact",
    //   "aligned_delimiter": false
    // }
    "default": true
  },
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nil",
  "nix.serverSettings": {
    "nil": {
      // "diagnostics": {
      //  "ignored": ["unused_binding", "unused_with"],
      // },
      "formatting": {
        "command": ["nixfmt"]
      }
    }
  },
  "notebook.lineNumbers": "on",
  "oxc.enable": true,
  "quotick.showWelcomeMessage": false,
  "remote.autoForwardPortsSource": "hybrid",
  "resmon.show.battery": false,
  "resmon.show.cpufreq": false,
  "resmon.show.cpuusage": false,
  "ruff.lineLength": 120,
  "rumdl.rules.enable": [
    "MD004", // Unordered list style
    "MD010", // Hard tabs
    "MD018", // No space after hash on atx style heading
    "MD024", // Multiple headings with the same content
    "MD026", // Trailing punctuation in heading
    "MD028", // Blank line inside blockquote
    "MD029", // Ordered list item prefix
    "MD031", // Fenced code blocks should be surrounded by blank lines
    // "MD033", // Inline HTML
    // "MD034", // Bare URL used
    "MD036", // Emphasis used instead of a heading
    "MD040", // Fenced code blocks should have a language specified
    "MD041", // First line in a file should be a top-level heading
    "MD045", // Images should have alternate text (alt text)
    // "MD051", // Link fragments should be valid
    "MD053", // Link and image reference definitions should be needed
    "MD058", // Tables should be surrounded by blank lines
    "MD060"
  ],
  "scm.repositories.explorer": true,
  "security.workspace.trust.untrustedFiles": "open",
  "settingsSync.ignoredExtensions": [
    // "qwtel.sqlite-viewer"
  ],
  "settingsSync.ignoredSettings": [
    // "-window.zoomLevel"
  ],
  "settingsSync.keybindingsPerPlatform": false,
  "tabout.enableReverseShiftTab": true,
  "tailwind-fold.autoFold": false,
  "tailwind-fold.foldStyle": "QUOTES",
  "tailwind-fold.unfoldIfLineSelected": true,
  "telemetry.telemetryLevel": "off",
  "terminal.external.linuxExec": "ghostty",
  "terminal.external.windowsExec": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.enableImages": true,
  "terminal.integrated.fontFamily": "'FiraCode Nerd Font', Consolas, monospace",
  "terminal.integrated.initialHint": false,
  "terminal.integrated.stickyScroll.enabled": false,
  "terminal.integrated.suggest.enabled": true,
  "terminal.integrated.windowsUseConptyDll": true,
  "testing.resultsView.layout": "treeLeft",
  "vim.disableExtension": true, // by default, false (enabled)
  // window
  "window.customTitleBarVisibility": "auto",
  "window.newWindowProfile": "Default",
  "window.zoomPerWindow": false,
  // workbench
  "workbench.activityBar.location": "top",
  "workbench.browser.enableChatTools": true,
  "workbench.colorCustomizations": {
    // dimidium
    "terminal.ansiBlack": "#000000",
    "terminal.ansiBlue": "#0575d8",
    "terminal.ansiBrightBlack": "#817e7e",
    "terminal.ansiBrightBlue": "#688dfd",
    "terminal.ansiBrightCyan": "#32e0fb",
    "terminal.ansiBrightGreen": "#37e57b",
    "terminal.ansiBrightMagenta": "#ed6fe9",
    "terminal.ansiBrightRed": "#ff643b",
    "terminal.ansiBrightWhite": "#d3d8d9",
    "terminal.ansiBrightYellow": "#fccd1a",
    "terminal.ansiCyan": "#1db6bb",
    "terminal.ansiGreen": "#60b442",
    "terminal.ansiMagenta": "#af5ed2",
    "terminal.ansiRed": "#cf494c",
    "terminal.ansiWhite": "#bab7b6",
    "terminal.ansiYellow": "#db9c11",
    "terminal.background": "#141414",
    "terminal.foreground": "#bab7b6",
    "terminal.selectionBackground": "#8db8e5",
    "terminalCursor.foreground": "#37e57b"
  },
  "workbench.colorTheme": "Nord",
  "workbench.editor.customLabels.patterns": {
    "**/index.{ts,tsx}": "${dirname}/index.${extname}",
    "**/src/**/{page,layout,index,route}.{ts,tsx}": "(${dirname})/${filename}.${extname}"
  },
  "workbench.editor.showTabIndex": true,
  "workbench.editor.useModal": "some",
  "workbench.iconTheme": "vscode-icons",
  "workbench.startupEditor": "none",
  "workbench.tree.indent": 20,
  "workbench.tree.renderIndentGuides": "always"
}
