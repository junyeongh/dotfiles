# pnpm
export PATH="$HOME/.local/bin:$PATH"
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
*":$PNPM_HOME:"*) ;;
*) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end

# Builtin command Aliases
alias mkdir='mkdir -pv'

function cd_ls() {
  builtin cd "$@" && ls -al
}
alias cd='cd_ls'

# Git aliases

alias gaa='git add .'
alias gaaa='git add --all'
alias gau='git add --update'
alias gb='git branch'
alias gbd='git branch --delete'
alias gc='git commit'
alias gcf='git commit --fixup'
alias gcm='git commit --message'
alias gd='git diff'
alias gda='git diff HEAD'
alias gi='git init'
alias gld='git log --pretty=format:"%h %ad %s" --date=short --all'
alias glg='git log --graph --oneline --decorate --all'
alias gm='git merge --no-ff'
alias gma='git merge --abort'
alias gmc='git merge --continue'
alias gp='git pull'
alias gpr='git pull --rebase'
alias gr='git rebase'
alias gs='git status'
alias gss='git status --short'
alias gst='git stash'
alias gstl='git stash list'
alias gsts='git stash --staged'
alias gwa='git worktree add'
alias gwr='git worktree remove'
alias gwl='git worktree list'

if command -v cargo &>/dev/null; then
  alias cargo-upgrade="cargo install $(cargo install --list | awk '/:$/ { print $1; }')"
fi
if command -v claude &>/dev/null; then
  alias claudex='claude --dangerously-skip-permissions'
fi
if command -v eza &>/dev/null; then
  alias ls='eza -all --icons --git --header --group-directories-first --sort=type'
  alias tree='eza -all --tree'
fi
if command -v fzf &>/dev/null; then
  alias fzfp='fzf --preview "bat --color=always --style=header,grid --line-range :500 {}"'
fi
if command -v gh &>/dev/null && gh auth status &>/dev/null; then
  export GITHUB_TOKEN=$(gh auth token)
  export MISE_GITHUB_TOKEN=$GITHUB_TOKEN
fi
if command -v lazydocker &>/dev/null; then
  alias ld='lazydocker'
fi
if command -v lazygit &>/dev/null; then
  alias lg='lazygit'
fi

# Update
if command -v pnpm &>/dev/null; then
  alias pnpm-up='pnpm update --global --latest'
fi

if command -v mise &>/dev/null; then
  alias mise-up='mise upgrade && mise prune --yes'
fi

# nix related
if command -v nix &>/dev/null; then
  alias nix-optimise="sudo nix-store --optimise"
  alias home-up="home-manager switch --flake ~/dotfiles#wsl"
fi

if command -v nixos-rebuild &>/dev/null; then
  alias nixos-up="sudo nixos-rebuild switch --flake ~/dotfiles#nixos"
  alias nixos-gens="nixos-rebuild list-generations"
fi
